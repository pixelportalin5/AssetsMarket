# AssetsMarket backend — single source of truth for DB, auth, and server config.
# Copy to backend/.env (never commit .env).

NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
API_VERSION=1.0.0
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# PostgreSQL — used by backend runtime AND Prisma (via packages/database scripts)
DATABASE_URL=postgresql://assetsmarket:assetsmarket@localhost:5432/assetsmarket?schema=public
DIRECT_URL=postgresql://assetsmarket:assetsmarket@localhost:5432/assetsmarket?schema=public

# Auth — generate unique 64+ char secrets for non-local environments
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
