# =============================================================================
# AssetsMarket — environment template
# Copy to:  backend/.env  |  frontend/.env.local
# Local DB/Redis:  pnpm docker:up  (when compose is added)
# =============================================================================

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL 17 (Docker: infrastructure/docker) ─────────────────────────────
# Prisma uses DATABASE_URL; DIRECT_URL bypasses pooler for migrations (optional locally)
DATABASE_URL=postgresql://assetsmarket:assetsmarket@localhost:5432/assetsmarket?schema=public
DIRECT_URL=postgresql://assetsmarket:assetsmarket@localhost:5432/assetsmarket?schema=public

# ─── Redis 7 (Docker) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Backend API ───────────────────────────────────────────────────────────────
PORT=4000
API_PREFIX=/api/v1
LOG_LEVEL=debug

# Auth (generate a strong secret for non-local environments)
JWT_SECRET=local-dev-only-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS (optional locally; required in staging/production) ────────────────────
AWS_REGION=us-east-1
S3_BUCKET=assetsmarket-dev-uploads

# ─── Frontend (Next.js — prefix required for browser exposure) ───────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
