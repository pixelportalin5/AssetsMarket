{
  "name": "@assetsmarket/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../backend/.env -- prisma generate",
    "db:migrate": "dotenv -e ../../backend/.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../backend/.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../backend/.env -- prisma studio",
    "db:push": "dotenv -e ../../backend/.env -- prisma db push",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "build": "dotenv -e ../../backend/.env -- prisma generate",
    "clean": "rimraf dist node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "catalog:"
  },
  "devDependencies": {
    "@assetsmarket/config-eslint": "workspace:*",
    "@assetsmarket/config-typescript": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "eslint": "catalog:",
    "prisma": "catalog:",
    "rimraf": "^6.0.1",
    "typescript": "catalog:"
  }
}
